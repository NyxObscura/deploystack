# Host + port the webhook server binds to. Put it behind nginx + TLS in production.
DEPLOYSTACK_HOST=127.0.0.1
DEPLOYSTACK_PORT=9000

# Path to the apps configuration file.
DEPLOYSTACK_CONFIG=/etc/deploystack/apps.yml

# Root directory that holds every app's releases/, shared/, current symlink.
# Must be writable by the deploystack system user.
DEPLOYSTACK_ROOT=/srv/apps

# Where deploy logs, server logs and state files live.
DEPLOYSTACK_DATA=/var/lib/deploystack

# Optional: restrict inbound webhook traffic to GitHub's hook source ranges only.
# Accepts "true" / "false". When true, the server fetches https://api.github.com/meta
# at boot and refreshes every 6h.
DEPLOYSTACK_GITHUB_IP_ALLOWLIST=false

# Log level: trace|debug|info|warn|error
LOG_LEVEL=info

# Maximum number of release directories to keep per app (older ones are pruned).
DEPLOYSTACK_KEEP_RELEASES=5

# Hard timeout (seconds) for a single deployment. After this, the deploy process is killed.
DEPLOYSTACK_DEPLOY_TIMEOUT=900
